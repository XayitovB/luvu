# Copy to .env and fill in real values before running docker compose.

# Git commit hash baked into asset URLs for cache-busting (?v=<hash>).
# Set automatically in CI/deploy scripts — safe to leave as "dev" locally.
GIT_COMMIT=dev

# Shared secret used to sign short-lived TURN credentials (coturn's
# "static-auth-secret" / REST-API scheme). Generate with: openssl rand -base64 32
TURN_SECRET=

# Public hostname or IP the browser connects to for TURN relay.
# Must NOT be a Cloudflare-proxied hostname — TURN needs to reach the
# origin directly on port 3478 (UDP/TCP), which a CDN proxy won't forward.
TURN_HOST=
